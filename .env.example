# =============================================================================
# Agisano site — environment
# Copy to .env.local and fill in. Nothing here is secret at build time: these
# are NEXT_PUBLIC_ values baked into the static export, so use a form service
# endpoint that is safe to expose (they all are — they're POST-only inboxes).
# =============================================================================

# The lead endpoint. The booking form POSTs JSON here.
#
# This is the n8n Webhook node on the VPS, e.g.
#   NEXT_PUBLIC_LEAD_ENDPOINT=https://n8n.<host>/webhook/agisano-lead
#
# ---------------------------------------------------------------------------
# !! THE n8n WEBHOOK MUST BE CONFIGURED FOR BROWSER POSTS OR THE FORM WILL FAIL
# ---------------------------------------------------------------------------
# The browser posts cross-origin from agisano.com, so on the n8n Webhook node:
#
#   1. HTTP Method            POST
#   2. Allowed Origins (CORS) https://agisano.com,https://www.agisano.com
#        Without this the browser blocks the request and NO lead arrives.
#        This is the single most likely thing to break — test it after setup.
#   3. Respond                "Immediately" (the form should not wait on a
#        long-running workflow; a slow response looks like a hang).
#
# The URL is public — anyone can POST to it. The form sends a `website`
# honeypot field: bots fill it, humans never see it. Drop any payload where
# `website` is non-empty at the top of the workflow.
#
# If this is EMPTY, the form does NOT fake a success. It tells the user online
# submission isn't connected and hands them working WhatsApp + email paths
# carrying the full lead. That is deliberate — see lib/lead.ts.
NEXT_PUBLIC_LEAD_ENDPOINT=

# WhatsApp click-to-chat number, international format, digits only, no +.
# e.g. 27821234567 for +27 82 123 4567
NEXT_PUBLIC_WHATSAPP=

# The inbox shown on the site and used for the mailto fallback.
NEXT_PUBLIC_EMAIL=
